{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "all": true,
      "nursery": {
        "all": false
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 15
          }
        },
        "noForEach": "off",
        "useLiteralKeys": "off",
        "noExcessiveNestedTestSuites": "off",
        "useSimplifiedLogicExpression": "off"
      },
      "correctness": {
        "noNodejsModules": "off"
      },
      "style": {
        "noDefaultExport": "off",
        "useNamingConvention": "off",
        "useFilenamingConvention": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none"
    },
    "globals": ["Bun", "React", "Timer"]
  },
  "files": {
    "ignore": ["node_modules/**", "dist/**", "coverage/**", "*.min.js"]
  },
  "overrides": [
    {
      "include": ["**/*.test.ts", "**/*.spec.ts", "tests/**/*.ts", "e2e/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off",
            "noEmptyBlockStatements": "off",
            "useAwait": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          }
        }
      }
    },
    {
      "include": [
        "src/index.ts",
        "src/ui.ts",
        "src/core/cli/**/*.ts",
        "src/core/daemon/**/*.ts",
        "src/utils/errors.ts",
        "src/utils/logger.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off",
            "noConsoleLog": "off",
            "noEmptyBlockStatements": "off"
          }
        }
      }
    },
    {
      "include": [
        "**/index.ts",
        "src/core/config/state-store.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off",
            "noReExportAll": "off"
          }
        }
      }
    },
    {
      "include": [
        "src/core/server/**/*.ts",
        "src/core/terminal/**/*.ts",
        "src/core/protocol/**/*.ts",
        "src/core/client/**/*.ts",
        "src/features/**/server/**/*.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "style": {
            "noParameterProperties": "off",
            "noNonNullAssertion": "off",
            "useDefaultSwitchClause": "off",
            "useCollapsedElseIf": "off"
          },
          "suspicious": {
            "noEmptyBlockStatements": "off",
            "useAwait": "off",
            "noEvolvingTypes": "off",
            "noControlCharactersInRegex": "off",
            "noAssignInExpressions": "off",
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "include": ["src/browser/**/*.ts", "src/browser/**/*.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useKeyWithClickEvents": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noVoid": "off",
            "noStaticOnlyClass": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "style": {
            "noParameterProperties": "off",
            "noNonNullAssertion": "off",
            "useDefaultSwitchClause": "off",
            "useCollapsedElseIf": "off"
          },
          "suspicious": {
            "noEmptyBlockStatements": "off",
            "noAssignInExpressions": "off",
            "noControlCharactersInRegex": "off"
          }
        }
      }
    },
    {
      "include": ["src/features/**/client/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noEmptyBlockStatements": "off"
          }
        }
      }
    }
  ]
}
