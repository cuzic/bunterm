{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "plugins": [
    "./rules/no-parent-relative-import.grit",
    "./rules/no-empty-catch.grit",
    "./rules/no-innerhtml-assignment.grit",
    "./rules/no-sync-fs-in-routes.grit",
    "./rules/no-as-any.grit",
    "./rules/no-direct-add-event-listener.grit",
    "./rules/no-node-fs-sync-import.grit",
    "./rules/no-as-never-in-elysia.grit",
    "./rules/no-store-cast-in-elysia.grit",
    "./rules/no-zod-in-elysia.grit",
    "./rules/no-raw-api-fetch.grit",
    "./rules/no-module-singleton-in-elysia.grit"
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "nursery": {},
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 15
          }
        },
        "noForEach": "off",
        "useLiteralKeys": "off",
        "noExcessiveNestedTestSuites": "off",
        "useSimplifiedLogicExpression": "off"
      },
      "correctness": {
        "noNodejsModules": "off"
      },
      "style": {
        "noDefaultExport": "off",
        "useNamingConvention": "off",
        "useFilenamingConvention": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none"
    },
    "globals": ["Bun", "React", "Timer"]
  },
  "files": {
    "includes": ["**", "!**/node_modules/**", "!**/dist/**", "!**/coverage/**", "!**/*.min.js"]
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.spec.ts", "**/tests/**/*.ts", "**/e2e/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off",
            "noEmptyBlockStatements": "off",
            "useAwait": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.js"],
      "linter": {
        "rules": {
          "correctness": {
            "noInnerDeclarations": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "suspicious": {
            "noControlCharactersInRegex": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "style": {
            "noDescendingSpecificity": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/src/index.ts",
        "**/src/ui.ts",
        "**/src/core/cli/**/*.ts",
        "**/src/core/daemon/**/*.ts",
        "**/src/utils/errors.ts",
        "**/src/utils/logger.ts",
        "**/src/utils/qr-terminal.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "suspicious": {
            "noConsole": "off",
            "noEmptyBlockStatements": "off"
          }
        }
      }
    },
    {
      "includes": ["**/index.ts", "**/src/core/config/state-store.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off",
            "noReExportAll": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/src/core/server/**/*.ts",
        "**/src/core/terminal/**/*.ts",
        "**/src/core/protocol/**/*.ts",
        "**/src/core/client/**/*.ts",
        "**/src/features/**/server/**/*.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "style": {
            "noParameterProperties": "off",
            "noNonNullAssertion": "off",
            "useDefaultSwitchClause": "off",
            "useCollapsedElseIf": "off"
          },
          "suspicious": {
            "noEmptyBlockStatements": "off",
            "useAwait": "off",
            "noEvolvingTypes": "off",
            "noControlCharactersInRegex": "off",
            "noAssignInExpressions": "off",
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["**/src/browser/**/*.ts", "**/src/browser/**/*.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useKeyWithClickEvents": "off",
            "noStaticElementInteractions": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noVoid": "off",
            "noStaticOnlyClass": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "style": {
            "noParameterProperties": "off",
            "noNonNullAssertion": "off",
            "useDefaultSwitchClause": "off",
            "useCollapsedElseIf": "off"
          },
          "suspicious": {
            "noEmptyBlockStatements": "off",
            "noAssignInExpressions": "off",
            "noControlCharactersInRegex": "off",
            "noArrayIndexKey": "off",
            "useIterableCallbackReturn": "off"
          }
        }
      }
    },
    {
      "includes": ["**/src/features/**/client/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noEmptyBlockStatements": "off"
          }
        }
      }
    }
  ]
}
